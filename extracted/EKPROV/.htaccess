# .htaccess - Configuración Apache para EK Proveedores MVC
# ACTUALIZADO: Diciembre 2025 - Corrección Error 500 y Optimizaciones

# =====================================================
# 1. CONFIGURACIÓN BÁSICA Y SEGURIDAD DEL NÚCLEO
# =====================================================
# Evitar que se listen los archivos de las carpetas (Seguridad)
Options -Indexes

# Prevenir conflictos de negociación de contenido
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    # NOTA: Si tus rutas fallan en la subcarpeta, descomenta la siguiente línea 
    # y pon la ruta correcta, ej: /urbano/ekprov/
    RewriteBase /urbano/ekprov/

    # -----------------------------------------------------
    # PROTECCIÓN DE CARPETAS Y ARCHIVOS SENSIBLES
    # -----------------------------------------------------
    
    # Bloquear acceso web directo a carpetas del sistema (Reemplaza a <Directory>)
    # Esto protege database, logs y uploads_privados de miradas externas
    RewriteRule ^(database|logs|uploads_privados|includes)/ - [F,L]

    # Bloquear acceso a archivos de configuración y control de versiones
    <FilesMatch "^\.env|\.git|composer\.json|composer\.lock|package\.json|README\.md|\.gitignore">
        Order allow,deny
        Deny from all
    </FilesMatch>

    # -----------------------------------------------------
    # REGLAS DE ENRUTAMIENTO (MVC)
    # -----------------------------------------------------

    # Forzar HTTPS (Opcional - Descomentar si tienes SSL activo y quieres forzarlo)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Ignorar archivos y directorios físicos reales (CSS, JS, Imágenes)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Todo lo demás se envía a index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# =====================================================
# 2. HEADERS DE SEGURIDAD (HARDENING)
# =====================================================
<IfModule mod_headers.c>
    # Evita que tu sitio sea incrustado en iframes de otros sitios (Clickjacking)
    Header set X-Frame-Options "SAMEORIGIN"

    # Evita que el navegador adivine tipos de archivo (MIME Sniffing)
    Header set X-Content-Type-Options "nosniff"

    # Protección básica XSS
    Header set X-XSS-Protection "1; mode=block"

    # Control de Referrer
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# =====================================================
# 3. RENDIMIENTO (COMPRESIÓN GZIP)
# =====================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# =====================================================
# 4. CACHE DE NAVEGADOR (Para velocidad)
# =====================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/x-javascript "access plus 1 month"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# =====================================================
# 5. CONFIGURACIÓN PHP
# =====================================================
# NOTA IMPORTANTE: Se han eliminado los 'php_value' porque causan Error 500
# en servidores con PHP FastCGI/CGI (Hostgator, cPanel estándar).
#
# Para cambiar el upload_max_filesize, debes crear un archivo llamado
# 'php.ini' o '.user.ini' en esta misma carpeta y poner la configuración allí.

# =====================================================
# 6. MANEJO DE ERRORES
# =====================================================
# Redirigir errores al router de la app
ErrorDocument 404 /urbano/ekprov/index.php?error=404
ErrorDocument 403 /urbano/ekprov/index.php?error=403
ErrorDocument 500 /urbano/ekprov/index.php?error=500