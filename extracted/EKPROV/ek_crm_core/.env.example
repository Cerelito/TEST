# .env.example - Copiar a .env y configurar con tus datos reales

# =====================================================
# APLICACIÓN
# =====================================================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tudominio.com/ekproveedores
APP_NAME="EK Proveedores"

# =====================================================
# BASE DE DATOS
# =====================================================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=erickedu_ekprov
DB_USERNAME=erickedu_ekprov
DB_PASSWORD=tu_password_seguro
DB_CHARSET=utf8mb4

# =====================================================
# CORREO SMTP (Gmail / SMTP de Hosting)
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=noreply@tudominio.com
SMTP_PASS=tu_password_app_gmail
MAIL_FROM=noreply@tudominio.com
MAIL_FROM_NAME="EK Proveedores"
MAIL_REPLY_TO=soporte@tudominio.com

# =====================================================
# SEGURIDAD
# =====================================================
SESSION_LIFETIME=30
BCRYPT_COST=12
CSRF_TOKEN_EXPIRY=3600

# =====================================================
# RUTAS
# =====================================================
# Ruta absoluta en el servidor (HostGator)
# Ejemplo: /home1/usuario/public_html/ekproveedores/
ROOT_PATH=/home1/erickedu/Controladores-Apotema/

# =====================================================
# EMAILS DE ADMINISTRACIÓN
# =====================================================
EMAIL_ADMIN=admin@ekproveedores.com
EMAIL_NOTIFICACIONES=notificaciones@tudominio.com
