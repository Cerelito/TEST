# EK Accesos — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Application
BASE_URL=https://apotemaone.com/urbano/ekusers
ADMIN_EMAIL=ecruz@urbanopark.com

# Encryption key for ERP credentials (AES-256-CBC).
# Must be at least 32 characters. Generate with: openssl rand -hex 32
EK_CRYPT_KEY=CHANGE_ME_use_openssl_rand_hex_32_output_here

# Database
DB_HOST=localhost
DB_NAME=controlekup
DB_USER=root
DB_PASS=

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@ekaccesos.com
MAIL_PASS=your_smtp_app_password_here
MAIL_FROM_NAME=EK Accesos
